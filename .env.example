# Environment variables that do NOT have defaults in compose.yaml
# Only these need to be defined in a .env file or in the environment when running the container

# Microsoft Entra ID (Azure AD) - required when AUTH_ENTRA_ENABLED is true
AUTH_ENTRA_TENANT_ID=tenant-id-example
AUTH_ENTRA_ALLOWED_GROUP_IDS=009a8cba-5e82-4f57-9192-40ba7eac65cd,7ab85212-fd0c-4f6b-bfc0-4f8a2c2d2e86 # fake group ids

# Optional multi-tenant configuration (JSON array). If set, this takes precedence
# over the legacy AUTH_ENTRA_TENANT_ID/AUTH_ENTRA_ALLOWED_GROUP_IDS variables.
AUTH_ENTRA_TENANTS='[{"tenantId":"defra-dev-tenant-id","allowedGroupIds":["009a8cba-5e82-4f57-9192-40ba7eac65cd"]},{"tenantId":"defra-tenant-id","allowedGroupIds":["7ab85212-fd0c-4f6b-bfc0-4f8a2c2d2e86"]}]'


# AWS Cognito (only required if AUTH_COGNITO_ENABLED is enabled)
AUTH_COGNITO_ENABLED=false
AUTH_COGNITO_TOKEN_URL=https://your-pool.auth.eu-west-2.amazoncognito.com/oauth2/token
AUTH_COGNITO_USER_POOL_ID=eu-west-2_XXXXXXXXX
AUTH_COGNITO_CLIENT_IDS=clientId1,clientId2

# dev dependent env vars
SONAR_TOKEN=your-personal-sonar-token # mandatory to enable pre-commit checks via SonarQube Cloud scanning
