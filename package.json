{
  "name": "fcp-sfd-object-processor",
  "version": "0.2.0",
  "description": "File upload and processing service for Single Front Door",
  "main": "src/index.js",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "docker:debug": "docker compose -f compose.yaml -f compose.debug.yaml -p 'fcp-sfd-object-processor' up",
    "docker:build": "docker compose build",
    "docker:dev": "docker compose up",
    "docker:dev:d": "docker compose up -d",
    "docker:stop": "docker compose down",
    "docker:stop:v": "docker compose down -v",
    "docker:test": "npm run lint && (mkdir -p coverage/.tmp 2>/dev/null || true) && docker compose -p fcp-sfd-object-processor-test down -v && docker compose -f compose.yaml -f compose.test.yaml -p fcp-sfd-object-processor-test run --build --rm fcp-sfd-object-processor",
    "docker:test:watch": "docker compose -p fcp-sfd-object-processor-test down -v && docker compose -f compose.yaml -f compose.test.yaml -f compose.test.watch.yaml -p fcp-sfd-object-processor-test run --build --rm fcp-sfd-object-processor",
    "generateOpenApiSpec": "node --experimental-vm-modules ./scripts/generate-openapi.js",
    "sonar": "node scripts/sonar-scan.js",
    "pretest": "npm run lint",
    "test": "rm -rf ./coverage/** && vitest run --coverage",
    "test:watch": "vitest watch",
    "lint": "npx eslint . --ext .js",
    "lint:fix": "npx eslint . --ext .js --fix",
    "start:watch": "nodemon --watch src --exec 'node --experimental-vm-modules --inspect=0.0.0.0 src/index.js'",
    "start:debug": "nodemon --watch src --exec 'node --experimental-vm-modules --inspect-brk=0.0.0.0 src/index.js'",
    "start": "node --experimental-vm-modules src/index.js"
  },
  "author": "Defra DDTS",
  "contributors": [
    "Amirs Ishmuhametovs <amirs.ishmuhametovs@defra.gov.uk>",
    "Simon Dunn <simon.dunn1@defra.gov.uk>",
    "Rana Salem <rana.salem@defra.gov.uk>"
  ],
  "license": "OGL-UK-3.0",
  "dependencies": {
    "@aws-sdk/client-s3": "3.1075.0",
    "@aws-sdk/client-sns": "3.1075.0",
    "@aws-sdk/s3-request-presigner": "3.1075.0",
    "@defra/fcp-audit-publisher": "1.0.7",
    "@defra/hapi-tracing": "1.30.0",
    "@elastic/ecs-pino-format": "1.5.0",
    "@fetchkit/ffetch": "5.5.4",
    "@hapi/boom": "10.0.1",
    "@hapi/hapi": "21.4.9",
    "@hapi/inert": "7.1.2",
    "@hapi/jwt": "3.2.4",
    "@hapi/vision": "7.0.3",
    "applicationinsights": "3.15.0",
    "aws-embedded-metrics": "4.2.1",
    "aws4": "1.13.2",
    "convict": "6.2.5",
    "convict-format-with-validator": "6.2.0",
    "global-agent": "4.1.3",
    "hapi-pino": "13.0.0",
    "hapi-pulse": "4.0.0",
    "hapi-swagger": "17.3.2",
    "http-status-codes": "2.3.0",
    "https-proxy-agent": "9.1.0",
    "joi": "18.2.3",
    "mongo-locks": "3.1.2",
    "mongodb": "7.3.0",
    "node-fetch": "3.3.2",
    "pino": "10.3.1",
    "pino-pretty": "13.1.3",
    "undici": "8.5.0"
  },
  "devDependencies": {
    "@fetchkit/chaos-fetch": "1.2.1",
    "@types/convict": "6.1.6",
    "@types/node": "22.13.4",
    "@types/webpack-assets-manifest": "5.1.4",
    "@vitest/coverage-v8": "4.1.8",
    "autoprefixer": "10.5.0",
    "dotenv": "17.4.2",
    "eslint": "9.39.4",
    "neostandard": "0.13.0",
    "nodemon": "3.1.14",
    "npm-run-all": "4.1.5",
    "vitest": "4.1.8"
  }
}
